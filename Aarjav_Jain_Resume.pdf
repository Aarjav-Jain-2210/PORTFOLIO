                                    class="w-12 h-12 bg-gray-700 hover:bg-gray-600 rounded-full flex items-center justify-center transition-colors group"
                                >
                                    <i class="fab fa-github text-xl group-hover:text-cyber-blue"></i>
                                </a>
                                <a 
                                    href="https://linkedin.com/in/aarjavjain" 
                                    target="_blank" 
                                    rel="noopener noreferrer"
                                    class="w-12 h-12 bg-blue-600 hover:bg-blue-500 rounded-full flex items-center justify-center transition-colors group"
                                >
                                    <i class="fab fa-linkedin text-xl group-hover:text-white"></i>
                                </a>
                                <a 
                                    href="mailto:aarjavjain2210@gmail.com"
                                    class="w-12 h-12 bg-red-600 hover:bg-red-500 rounded-full flex items-center justify-center transition-colors group"
                                >
                                    <i class="fas fa-envelope text-xl group-hover:text-white"></i>
