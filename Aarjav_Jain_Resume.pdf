    <!-- Contact Section -->
    <section id="contact" class="py-20 bg-dark-bg">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="font-orbitron text-4xl font-bold text-cyber-blue mb-4">Let's Connect</h2>
                <div class="w-20 h-1 bg-gradient-to-r from-cyber-blue to-cyber-purple mx-auto"></div>
                <p class="text-gray-400 mt-4 max-w-2xl mx-auto">
                    Ready to collaborate? Let's build something amazing together!
                </p>
            </div>

            <div class="max-w-4xl mx-auto">
                <div class="grid md:grid-cols-2 gap-12">
                    
                    <!-- Contact Form -->
                    <div class="bg-dark-card p-8 rounded-xl border border-cyber-blue/20">
                        <h3 class="font-orbitron text-2xl font-bold text-cyber-blue mb-6">Send Message</h3>
                        <form id="contact-form" class="space-y-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">Name</label>
                                <input 
                                    type="text" 
                                    id="name"
                                    name="name"
                                    class="w-full bg-dark-bg border border-gray-600 rounded-lg px-4 py-3 text-white focus:border-cyber-blue focus:ring-1 focus:ring-cyber-blue transition-colors" 
                                    placeholder="Your Name"
                                    required
                                />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                                <input 
                                    type="email" 
                                    id="email"
                                    name="email"
                                    class="w-full bg-dark-bg border border-gray-600 rounded-lg px-4 py-3 text-white focus:border-cyber-blue focus:ring-1 focus:ring-cyber-blue transition-colors" 
                                    placeholder="your.email@example.com"
                                    required
                                />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">Message</label>
                                <textarea 
                                    rows="4" 
                                    id="message"
                                    name="message"
                                    class="w-full bg-dark-bg border border-gray-600 rounded-lg px-4 py-3 text-white focus:border-cyber-blue focus:ring-1 focus:ring-cyber-blue transition-colors" 
                                    placeholder="Tell me about your project..."
                                    required
                                ></textarea>
                            </div>
                            <button 
                                type="submit" 
                                class="glow-button w-full bg-gradient-to-r from-cyber-blue to-cyber-purple py-3 rounded-lg font-semibold text-white hover:scale-105 transition-all duration-300"
                            >
                                <i class="fas fa-paper-plane mr-2"></i>Send Message
                            </button>
                        </form>
                    </div>

                    <!-- Contact Info -->
                    <div class="space-y-8">
                        <div class="bg-dark-card p-8 rounded-xl border border-cyber-purple/20">
                            <h3 class="font-orbitron text-2xl font-bold text-cyber-purple mb-6">Get In Touch</h3>
                            <div class="space-y-4">
                                <div class="flex items-center space-x-4">
                                    <div class="w-12 h-12 bg-cyber-blue/20 rounded-full flex items-center justify-center">
                                        <i class="fas fa-envelope text-cyber-blue"></i>
                                    </div>
                                    <div>
                                        <p class="text-gray-300">Email</p>
                                        <p class="text-white font-semibold">aarjavjain2210@gmail.com</p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-4">
                                    <div class="w-12 h-12 bg-cyber-purple/20 rounded-full flex items-center justify-center">
                                        <i class="fas fa-phone text-cyber-purple"></i>
                                    </div>
                                    <div>
                                        <p class="text-gray-300">Phone</p>
                                        <p class="text-white font-semibold">+91 7017589301</p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-4">
                                    <div class="w-12 h-12 bg-cyber-pink/20 rounded-full flex items-center justify-center">
                                        <i class="fas fa-map-marker-alt text-cyber-pink"></i>
                                    </div>
                                    <div>
                                        <p class="text-gray-300">Location</p>
                                        <p class="text-white font-semibold">Dehradun, India</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Social Links -->
                        <div class="bg-dark-card p-8 rounded-xl border border-cyber-pink/20">
                            <h3 class="font-orbitron text-2xl font-bold text-cyber-pink mb-6">Social Links</h3>
                            <div class="flex space-x-4">
                                <a 
